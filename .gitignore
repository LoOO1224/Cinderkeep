# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
# Recommended: add any editor/OS/tool-specific ignore rules from the Global/ templates as needed.
# See: https://github.com/github/gitignore/tree/main/Global
#
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
*.blend1
*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/[Mm]emoryCaptures/

# Recordings can get excessive in size
/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
*.DotSettings.user

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Mono auto generated files
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
*.exe
*.zip
*.rar
*.7z
*.dmg
*.ipa

# Build exports / release packages
/[Rr]elease/
/[Rr]eleases/
/[Dd]ist/
/[Oo]utput/

# Unity / platform build caches
/[Ss]witchIL2CPPCache/
/[Ss]witchIL2CPPStats/

# Crashlytics generated file
crashlytics-build.properties

# TestRunner generated files
InitTestScene*.unity*

# Addressables default ignores, before user customizations
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Auto-generated cache in Assets folder
/[Aa]ssets/[Ss]ceneDependencyCache*

# IDE files
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
._*
.Spotlight-V100
.Trashes

# Extra Visual Studio local files
*.rsuser
*.userosscache
*.sln.docstates

# Local env / secrets
.env
.env.*
!.env.example

# Paid or private third-party Unity assets
# Keep purchased assets here locally, but never commit them to this public repo.
Assets/ThirdParty_PriAsset/
Assets/ThirdParty_PriAsset.meta
Assets/ThirdParty_Premium/
Assets/ThirdParty_Premium.meta
Assets/ThirdParty/AssetStore/Paid/**
Assets/ThirdParty/PrivateAssets/**

# External large terrain texture packs for Cinderkeep map work.
# Download these locally from the team drive when needed, but never commit them.
Assets/ThirdParty/AssetStore/Free/MicroVerse-Extras/
Assets/ThirdParty/AssetStore/Free/MicroVerse-Extras.meta
Assets/ThirdParty/AssetStore/Free/DW_TerrainTextures/
Assets/ThirdParty/AssetStore/Free/DW_TerrainTextures.meta
Assets/ThirdParty/AssetStore/Free/DW_Terrain_Textures/
Assets/ThirdParty/AssetStore/Free/DW_Terrain_Textures.meta
Assets/ThirdParty/AssetStore/Free/DW_Terrain Textures/
Assets/ThirdParty/AssetStore/Free/DW_Terrain Textures.meta
Assets/ThirdParty/AssetStore/Free/DW_Terrain Texures/
Assets/ThirdParty/AssetStore/Free/DW_Terrain Texures.meta
Assets/ThirdParty/Free/MicroVerse-Extras/
Assets/ThirdParty/Free/MicroVerse-Extras.meta
Assets/ThirdParty/Free/DW_TerrainTextures/
Assets/ThirdParty/Free/DW_TerrainTextures.meta
Assets/ThirdParty/Free/DW_Terrain_Textures/
Assets/ThirdParty/Free/DW_Terrain_Textures.meta
Assets/ThirdParty/Free/DW_Terrain Textures/
Assets/ThirdParty/Free/DW_Terrain Textures.meta
Assets/ThirdParty/Free/DW_Terrain Texures/
Assets/ThirdParty/Free/DW_Terrain Texures.meta
Assets/AllSkyFree/
Assets/AllSkyFree.meta
Assets/Blink/
Assets/Blink.meta
Assets/FeonY/
Assets/FeonY.meta
Assets/MicroVerse-Extras/
Assets/MicroVerse-Extras.meta

# Local plugin/editor preferences
ProjectSettings/HueFolders_Prefs.json

# Local Codex/generated asset analysis tools
tools/cinderkeep_asset_excel/

# Local recovery scenes
Assets/_Recovery/
Assets/_Recovery.meta

# Optional generated content.
# Enable these only if the team does not version built asset bundles.
# /[Aa]sset[Bb]undles/

# Extra crash / dump files
*.dmp
*.stackdump
Assets/ThirdParty/PlayModeComponentSaver
Assets/ThirdParty/PlayModeComponentSaver.meta

# Local source textures for imported free tool assets. Keep main below asset-size budget.
/Assets/ThirdParty/Free/Equipment/Stylized 3D Tools/Textures/*.psd
/Assets/ThirdParty/Free/Equipment/Stylized 3D Tools/Textures/*.PSD
/Assets/ThirdParty/Free/Equipment/Stylized 3D Tools/Textures/*.psd.meta
/Assets/ThirdParty/Free/Equipment/Stylized 3D Tools/Textures/*.PSD.meta
ProjectSettings/Packages/com.unity.probuilder
